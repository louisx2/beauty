{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "beauty",
  "compatibility_date": "2026-05-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "vscode/dist"
  },
  "build": {
    "command": "npm --prefix vscode install && npm --prefix vscode run build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
